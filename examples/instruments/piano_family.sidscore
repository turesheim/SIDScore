; Shared piano-like instrument
; This aims at a practical SID piano approximation: fast transient, quick decay,
; and low sustain

TABLE filter PianoCutoff {
  1800 @2         ; open at attack
  1400 @4
  1100 @6
  900  @8
  750  HOLD       ; settles darker for tail
}


INSTR piano
  WAVE=PULSE ADSR=1,9,0,0 PW=$0800
  FILTER=LP CUTOFF=1600 RES=1
  GATE=RETRIGGER GATEMIN=1
  FILTERSEQ=PianoCutoff
